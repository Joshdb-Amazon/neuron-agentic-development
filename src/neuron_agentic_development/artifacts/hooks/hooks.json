{
  "description": "NKI development environment hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-env.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
